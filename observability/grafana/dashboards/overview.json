{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Service Health",
      "type": "stat",
      "gridPos": { "h": 4, "w": 24, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "mappings": [
            { "options": { "0": { "text": "DOWN" }, "1": { "text": "UP" } }, "type": "value" }
          ]
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "expr": "up{job=~\"payment-service|otel-collector|prometheus\"}",
          "legendFormat": "{{job}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Request Throughput (req/s)",
      "description": "How many requests per second is each endpoint actually completing? A plateau here means something is bottlenecked.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 15,
            "lineWidth": 2,
            "showPoints": "never",
            "spanNulls": true
          },
          "unit": "reqps"
        },
        "overrides": []
      },
      "options": {
        "legend": { "calcs": ["mean", "lastNotNull"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{job=\"payment-service\", uri=\"/api/payments\"}[1m]))",
          "legendFormat": "payment-service /api/payments",
          "refId": "A"
        },
        {
          "expr": "sum(rate(tomcat_global_request_seconds_count{job=\"payment-service\"}[1m]))",
          "legendFormat": "payment-service (all)",
          "refId": "B"
        }
      ]
    },
    {
      "title": "Average Response Time (seconds)",
      "description": "Average time to process a request. Compare across services — which one is slow?",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 2,
            "showPoints": "never",
            "spanNulls": true
          },
          "unit": "s"
        },
        "overrides": []
      },
      "options": {
        "legend": { "calcs": ["mean", "lastNotNull"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "expr": "rate(http_server_requests_seconds_sum{job=\"payment-service\", uri=\"/api/payments\"}[1m]) / rate(http_server_requests_seconds_count{job=\"payment-service\", uri=\"/api/payments\"}[1m])",
          "legendFormat": "payment /api/payments (avg)",
          "refId": "A"
        },
        {
          "expr": "http_server_requests_seconds_max{job=\"payment-service\", uri=\"/api/payments\"}",
          "legendFormat": "payment /api/payments (max)",
          "refId": "B"
        }
      ]
    },
    {
      "title": "Max Request Latency (seconds)",
      "description": "The slowest single request in the window. A consistently high max suggests queuing.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 2,
            "showPoints": "never",
            "spanNulls": true
          },
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "red", "value": 1 }
            ]
          },
          "custom.thresholdsStyle": { "mode": "line" }
        },
        "overrides": []
      },
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "expr": "tomcat_global_request_max_seconds{job=\"payment-service\"}",
          "legendFormat": "payment-service max latency",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Active Connections vs Thread Pool",
      "description": "When connections exceed available threads, requests must wait. The gap between these lines is your queue depth.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 15,
            "lineWidth": 2,
            "showPoints": "never",
            "spanNulls": true
          },
          "unit": "short"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "max threads (capacity)" },
            "properties": [
              { "id": "custom.lineStyle", "value": { "fill": "dash", "dash": [10, 10] } },
              { "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } },
              { "id": "custom.fillOpacity", "value": 0 }
            ]
          }
        ]
      },
      "options": {
        "legend": { "calcs": ["lastNotNull"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "expr": "tomcat_connections_current_connections{job=\"payment-service\"}",
          "legendFormat": "active connections (demand)",
          "refId": "A"
        },
        {
          "expr": "tomcat_threads_busy_threads{job=\"payment-service\"}",
          "legendFormat": "busy threads (processing)",
          "refId": "B"
        },
        {
          "expr": "tomcat_threads_config_max_threads{job=\"payment-service\"}",
          "legendFormat": "max threads (capacity)",
          "refId": "C"
        }
      ]
    },
    {
      "title": "Tomcat Thread Pool Utilization (%)",
      "description": "What percentage of available threads are busy? 100% means every request must wait.",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "percentage",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 60 },
              { "color": "orange", "value": 80 },
              { "color": "red", "value": 95 }
            ]
          },
          "max": 100,
          "min": 0,
          "unit": "percent"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "showThresholdLabels": true,
        "showThresholdMarkers": true
      },
      "targets": [
        {
          "expr": "100 * tomcat_threads_busy_threads{job=\"payment-service\"} / tomcat_threads_config_max_threads{job=\"payment-service\"}",
          "legendFormat": "thread utilization",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Database Connection Pool",
      "description": "HikariCP pool health. If pending > 0, threads are waiting for DB connections.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 15,
            "lineWidth": 2,
            "showPoints": "never",
            "spanNulls": true
          },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "legend": { "calcs": ["lastNotNull"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "expr": "hikaricp_connections_active{job=\"payment-service\"}",
          "legendFormat": "active",
          "refId": "A"
        },
        {
          "expr": "hikaricp_connections_idle{job=\"payment-service\"}",
          "legendFormat": "idle",
          "refId": "B"
        },
        {
          "expr": "hikaricp_connections_max{job=\"payment-service\"}",
          "legendFormat": "max",
          "refId": "C"
        },
        {
          "expr": "hikaricp_connections_pending{job=\"payment-service\"}",
          "legendFormat": "pending (waiting!)",
          "refId": "D"
        }
      ]
    },
    {
      "title": "CPU & Memory",
      "description": "System resource usage. If these look normal but latency is high, the bottleneck is elsewhere.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 15,
            "lineWidth": 2,
            "showPoints": "never",
            "spanNulls": true
          },
          "unit": "bytes"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "JVM live threads" },
            "properties": [
              { "id": "unit", "value": "short" },
              { "id": "custom.axisPlacement", "value": "right" }
            ]
          }
        ]
      },
      "options": {
        "legend": { "calcs": ["lastNotNull"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "expr": "jvm_memory_used_bytes{job=\"payment-service\", area=\"heap\"}",
          "legendFormat": "heap used",
          "refId": "A"
        },
        {
          "expr": "jvm_memory_max_bytes{job=\"payment-service\", area=\"heap\"}",
          "legendFormat": "heap max",
          "refId": "B"
        },
        {
          "expr": "jvm_threads_live_threads{job=\"payment-service\"}",
          "legendFormat": "JVM live threads",
          "refId": "C"
        }
      ]
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "tags": ["bugbuster", "overview"],
  "templating": { "list": [] },
  "time": { "from": "now-15m", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "BugBuster Overview",
  "uid": "bugbuster-overview",
  "version": 1
}
